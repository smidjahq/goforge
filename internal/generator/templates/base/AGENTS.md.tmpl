## Extending the Project

### Add a new entity (e.g. `Order`)

**1. Create the domain struct** at `internal/entity/order.go`:

```go
package entity

type Order struct {
	ID     int64
	UserID int64
	Total  float64
}
```
{{- if ne .DB "none"}}

**2. Create the repo** at `internal/repo/persistent/order_repo.go`:
{{- if or (eq .DB "postgres-gorm") (eq .DB "sqlite-gorm") (eq .DB "mysql-gorm")}}

```go
package persistent

import (
	"{{.Module}}/internal/entity"
	"gorm.io/gorm"
)

type OrderRepo struct{ db *gorm.DB }

func NewOrderRepo(db *gorm.DB) *OrderRepo { return &OrderRepo{db: db} }

func (r *OrderRepo) GetByID(id int64) (*entity.Order, error) {
	var o entity.Order
	return &o, r.db.First(&o, id).Error
}

func (r *OrderRepo) Save(o *entity.Order) error {
	return r.db.Save(o).Error
}
```
{{- end}}
{{- if or (eq .DB "postgres-sqlc") (eq .DB "mysql-sqlc")}}

Write SQL in `internal/repo/persistent/queries/order.sql`:

```sql
-- name: GetOrder :one
SELECT * FROM orders WHERE id = $1;

-- name: CreateOrder :one
INSERT INTO orders (user_id, total) VALUES ($1, $2) RETURNING *;
```

Then run `sqlc generate` and implement the generated interface in `order_repo.go`.
{{- end}}
{{- if or (eq .DB "postgres-raw") (eq .DB "sqlite-raw") (eq .DB "mysql-raw")}}

```go
package persistent

import (
	"context"
	"database/sql"
	"{{.Module}}/internal/entity"
)

type OrderRepo struct{ db *sql.DB }

func NewOrderRepo(db *sql.DB) *OrderRepo { return &OrderRepo{db: db} }

func (r *OrderRepo) GetByID(ctx context.Context, id int64) (*entity.Order, error) {
	var o entity.Order
	row := r.db.QueryRowContext(ctx,
		"SELECT id, user_id, total FROM orders WHERE id = $1", id)
	return &o, row.Scan(&o.ID, &o.UserID, &o.Total)
}
```
{{- end}}
{{- end}}

**{{if ne .DB "none"}}3{{else}}2{{end}}. Create the usecase** at `internal/usecase/order.go`:

```go
package usecase

import "{{.Module}}/internal/entity"

type OrderRepo interface {
	GetByID(id int64) (*entity.Order, error)
}

type OrderUseCase struct{ repo OrderRepo }

func NewOrderUseCase(r OrderRepo) *OrderUseCase { return &OrderUseCase{repo: r} }

func (uc *OrderUseCase) Get(id int64) (*entity.Order, error) {
	return uc.repo.GetByID(id)
}
```

**{{if ne .DB "none"}}4{{else}}3{{end}}. Wire in `internal/app/app.go`** — initialise the repo, pass it to the usecase constructor, and pass the usecase to the handler.

