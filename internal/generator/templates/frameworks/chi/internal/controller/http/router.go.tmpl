package controller

import (
	"encoding/json"
	"net/http"
{{- $hasDB := ne .DB "none"}}

	"github.com/go-chi/chi/v5"
	chiMiddleware "github.com/go-chi/chi/v5/middleware"

	handler "{{.Module}}/internal/controller/http/handler"
	mw "{{.Module}}/internal/controller/http/middleware"
	"{{.Module}}/internal/usecase"
	"{{.Module}}/pkg/logger"
)

// NewRouter builds and returns the Chi HTTP handler with all routes registered.
func NewRouter(log logger.Logger{{if $hasDB}}, personSvc *usecase.PersonService{{end}}, postSvc *usecase.PostService) http.Handler {
	r := chi.NewRouter()
	r.Use(chiMiddleware.Recoverer)
	r.Use(mw.Logger(log))
	r.Use(mw.CORS())

	r.Get("/", func(w http.ResponseWriter, _ *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		_ = json.NewEncoder(w).Encode(map[string]string{
			"service": "{{.Name}}",
			"version": "0.1.0",
			"status":  "running",
		})
	})

	r.Get("/healthz", func(w http.ResponseWriter, _ *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		_ = json.NewEncoder(w).Encode(map[string]string{"status": "ok"})
	})

	r.Route("/api/v1", func(r chi.Router) {
{{- if $hasDB}}
		personH := handler.NewPersonHandler(personSvc)
		r.Post("/persons", personH.Create)
		r.Get("/persons", personH.List)
{{- end}}
		postH := handler.NewPostHandler(postSvc)
		r.Get("/posts", postH.List)
	})

	return r
}
