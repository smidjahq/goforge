package controller

import (
	"net/http"
{{- $hasDB := ne .DB "none"}}

	"github.com/gin-gonic/gin"

	handler "{{.Module}}/internal/controller/http/handler"
	mw "{{.Module}}/internal/controller/http/middleware"
	"{{.Module}}/internal/usecase"
	"{{.Module}}/pkg/logger"
)

// NewRouter builds and returns the Gin HTTP handler with all routes registered.
func NewRouter(log logger.Logger{{if $hasDB}}, personSvc *usecase.PersonService{{end}}, postSvc *usecase.PostService) http.Handler {
	r := gin.New()
	r.Use(gin.Recovery())
	r.Use(mw.Logger(log))
	r.Use(mw.CORS())

	r.GET("/", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{
			"service": "{{.Name}}",
			"version": "0.1.0",
			"status":  "running",
		})
	})

	r.GET("/healthz", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{"status": "ok"})
	})

	api := r.Group("/api/v1")
{{- if $hasDB}}
	{
		personH := handler.NewPersonHandler(personSvc)
		api.POST("/persons", personH.Create)
		api.GET("/persons", personH.List)
	}
{{- end}}
	{
		postH := handler.NewPostHandler(postSvc)
		api.GET("/posts", postH.List)
	}

	return r
}
