package persistent

import (
	"context"
	"fmt"
	"time"

	"{{.Module}}/internal/entity"
)

// PersonRepo implements usecase.PersonRepo using pgx directly.
// When you run `sqlc generate`, replace the body of each method with the
// generated Queries calls (e.g. q.CreatePerson, q.ListPersons).
type PersonRepo struct {
	db *Pool
}

// NewPersonRepo creates a PersonRepo backed by the given connection pool.
func NewPersonRepo(db *Pool) *PersonRepo {
	return &PersonRepo{db: db}
}

// Create inserts a new Person and returns the persisted record.
func (r *PersonRepo) Create(ctx context.Context, name string) (*entity.Person, error) {
	now := time.Now().UTC()
	row := r.db.Conn.QueryRow(ctx,
		`INSERT INTO persons (name, created_at, updated_at)
		 VALUES ($1, $2, $2)
		 RETURNING id, name, created_at, updated_at`,
		name, now,
	)

	var p entity.Person
	if err := row.Scan(&p.ID, &p.Name, &p.CreatedAt, &p.UpdatedAt); err != nil {
		return nil, fmt.Errorf("create person: %w", err)
	}
	return &p, nil
}

// FindAll returns all Person records ordered by ID.
func (r *PersonRepo) FindAll(ctx context.Context) ([]*entity.Person, error) {
	rows, err := r.db.Conn.Query(ctx,
		`SELECT id, name, created_at, updated_at FROM persons ORDER BY id`,
	)
	if err != nil {
		return nil, fmt.Errorf("list persons: %w", err)
	}
	defer rows.Close()

	var persons []*entity.Person
	for rows.Next() {
		var p entity.Person
		if err := rows.Scan(&p.ID, &p.Name, &p.CreatedAt, &p.UpdatedAt); err != nil {
			return nil, fmt.Errorf("scan person: %w", err)
		}
		persons = append(persons, &p)
	}
	return persons, rows.Err()
}
