services:
  db:
    image: mysql:8
    environment:
      MYSQL_DATABASE: {{.Name}}
      MYSQL_USER: mysql
      MYSQL_PASSWORD: mysql
      MYSQL_ROOT_PASSWORD: root
    ports:
      - "3306:3306"
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "mysql", "-pmysql"]
      interval: 10s
      timeout: 5s
      retries: 5
